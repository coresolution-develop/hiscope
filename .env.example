POSTGRES_DB=hiscope_eval
POSTGRES_USER=hiscope
POSTGRES_PASSWORD=change-me

# Local profile default:
# DB_URL=jdbc:h2:file:./data/h2db/hiscope_local;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE
# (./gradlew clean does not remove ./data/h2db. Delete ./data/h2db manually to reset local data.)

APP_BOOTSTRAP_SUPER_ADMIN_ENABLED=false
APP_BOOTSTRAP_SUPER_ADMIN_LOGIN_ID=super
APP_BOOTSTRAP_SUPER_ADMIN_PASSWORD=change-me
APP_UPLOAD_MAX_FILE_SIZE_BYTES=10485760
APP_UPLOAD_MAX_ROWS=5000

# MyPage AI summary (OpenAI)
MYPAGE_AI_PROVIDER=HEURISTIC
MYPAGE_AI_ENABLED=false
MYPAGE_AI_FALLBACK_TO_HEURISTIC=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=10s
OPENAI_MAX_RETRIES=1
